# Copy to .env and fill in. NEVER commit .env.
#
# Default provider is Gemini (free tier, no credit card).
# Get a free key at: https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GOOGLE_API_KEY=your-google-ai-studio-key-here

# To run the tutorial's original OpenAI setup instead, set:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-your-openai-key-here
# OpenAI is NOT free — it needs prepaid API credit (~$5 min).
